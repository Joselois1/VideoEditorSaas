# ---------- Google AdSense ----------
# Publisher ID (ca-pub-XXXXXXXXXXXXXXXX). Dejar vacio hasta que AdSense apruebe el sitio.
# Si esta vacio, no se carga el script de AdSense y los banners muestran un placeholder.
NEXT_PUBLIC_ADSENSE_CLIENT=

# Slot ID del bloque de anuncios (numero de 10 digitos).
NEXT_PUBLIC_ADSENSE_SLOT=

# ---------- Dominio ----------
# Dominio canonico sin protocolo (usado por metadata y archivos publicos).
NEXT_PUBLIC_SITE_DOMAIN=clipcut.xyz

# ---------- Plan Pro (oculto por defecto) ----------
# Setear "true" para mostrar el flujo de upgrade y ocultar anuncios a usuarios Pro.
NEXT_PUBLIC_PRO_ENABLED=false
